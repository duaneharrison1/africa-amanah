---
import Base from '../layouts/Base.astro';
import { ASSET } from '../data/site.js';

const HERO_PHOTO = 'https://africaamanah.com/wp-content/uploads/2025/07/jeff-ackley-YwDo_HwORXs-unsplash-scaled.jpg';
const HADIM = 'https://africaamanah.com/wp-content/uploads/2025/06/Frame-1707483754-1.png';
const COLLAGE = 'https://africaamanah.com/wp-content/uploads/2025/06/unnamed-file.png';

const stats = [
  { icon: '2025/07/tdesign_rice-filled.svg', num: '$ 1,100 USD', label: 'Donated to Widows and Orphans' },
  { icon: '2025/06/lucide-lab_onion.svg', num: '200', label: 'bags of rice' },
  { icon: '2025/06/Frame-1707483721.svg', num: '70', label: 'bags of biscuits' },
  { icon: '2025/06/mdi_spoon-sugar.svg', num: '100', label: 'bags of sugar' },
];
const highlights = [
  { icon: '2025/06/Frame-8.svg', title: 'Community Engagement', text: 'Local volunteers and community members actively supported the distribution process.' },
  { icon: '2025/06/Frame-8-1.svg', title: 'Impact', text: 'The initiative eased Ramadan hardship for vulnerable families with food and financial relief.' },
  { icon: '2025/06/Frame-8-2.svg', title: 'Visibility', text: 'Branded T-shirts and banners helped raise awareness of the foundation’s efforts.' },
];
const gallery = [
  'https://africaamanah.com/wp-content/uploads/2025/06/C92EAEEB-6766-431C-B15C-025053F3A984.png',
  'https://africaamanah.com/wp-content/uploads/2025/06/BC05E838-CF3C-45CB-B6E4-9A20F51B5EE6.png',
  'https://africaamanah.com/wp-content/uploads/2025/06/IMG_3863.png',
];
---
<Base title="Charity Report 2025 — Africa Amanah Foundation">
  <!-- HERO -->
  <section class="report-hero">
    <span class="rings" style="top:-90px;right:-120px;width:560px;height:560px" aria-hidden="true"></span>
    <div class="container" style="position:relative;z-index:1">
      <div class="report-hero-grid">
        <div>
          <h1>Charity Outreach Report April 2025</h1>
          <p class="report-meta">📍 Community: North Bank, South Bank and &amp; Kanifing&nbsp;&nbsp;&nbsp;📅 Date: 13th - 15th April 2025</p>
        </div>
      </div>
      <div class="report-hero-photo">
        <img src={HERO_PHOTO} alt="Africa Amanah Foundation outreach" />
      </div>
    </div>
  </section>

  <!-- INTRO + STATS -->
  <section class="report-stats">
    <div class="container">
      <div class="report-stats-grid">
        <p class="report-intro">From April 13–15, 2025, Baseng Foundation distributed food and cash aid to over 500 households across 3 provinces in the Gambia.</p>
        <div class="stat-list">
          {stats.map((s) => (
            <div class="stat-fig">
              <div class="stat-fig-top">
                <span class="stat-chip"><img src={`${ASSET}/${s.icon}`} alt="" /></span>
                <span class="stat-fig-num">{s.num}</span>
              </div>
              <div class="stat-fig-label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- OBJECTIVE (dark) -->
  <section class="section-dark report-objective">
    <span class="rings" style="top:-40px;left:-160px;width:560px;height:560px" aria-hidden="true"></span>
    <div class="container" style="position:relative;z-index:1">
      <div class="report-objective-grid">
        <h2>Objective</h2>
        <p>To provide essential food commodities and cash donations to ease the hardships experienced by underprivileged families, especially the elderly, widows, and vulnerable groups during the holy month of Ramadan. The outreach aimed to support over 500 households across 3 provinces in the Gambia.</p>
      </div>
    </div>
  </section>

  <!-- OUTREACH HIGHLIGHT -->
  <section class="report-highlights">
    <div class="container">
      <h2 class="center" style="margin-bottom:48px">Outreach Highlight</h2>
      <div class="grid grid-3">
        {highlights.map((h) => (
          <div class="highlight-card">
            <span class="highlight-icon"><img src={`${ASSET}/${h.icon}`} alt="" /></span>
            <h4>{h.title}</h4>
            <p>{h.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CHALLENGES (soft) -->
  <section class="section-soft report-split">
    <div class="container">
      <div class="report-split-grid">
        <h2>Challenges</h2>
        <div class="stack">
          <p>The main challenges faced during the initiative were:</p>
          <ul class="challenge-list">
            <li><strong>Transportation Difficulties:</strong> Limited vehicle availability and logistics coordination.</li>
            <li><strong>Rising Commodity Costs:</strong> The increasing prices of staple food items impacted budgeting.</li>
          </ul>
          <p>Despite these hurdles, the leadership of charity distribution coordinator Fatim Badjie (Baseng Foundation) ensured smooth and effective execution.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONCLUSION -->
  <section class="report-split">
    <div class="container">
      <div class="report-split-grid">
        <h2>Conclusion</h2>
        <div class="stack">
          <p>The Ramadan outreach was met with overwhelming gratitude and appreciation from the communities served. One elderly beneficiary expressed how the support brought “nourishment and hope” and reinforced community unity and compassion. The initiative significantly alleviated suffering during Ramadan and highlighted the impact of collective kindness.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="report-gallery">
    <div class="container">
      <div class="gallery-row">
        {gallery.map((g) => (
          <div class="gallery-shot"><img src={g} alt="Outreach photo" /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ACKNOWLEDGMENTS (soft, centered) -->
  <section class="section-soft report-ack">
    <div class="container-narrow center">
      <h2>Acknowledgments</h2>
      <hr class="ack-rule" />
      <p class="lead mx-auto">Sincere thanks to all donors, volunteers, and community members who made the program a success.</p>
      <div class="ack-person">
        <img src={HADIM} alt="Hadim Ceesay" />
        <h4>Hadim Ceesay</h4>
      </div>
    </div>
  </section>

  <!-- CLOSING QUOTE -->
  <section class="quote-collage" style={`--collage:url('${COLLAGE}')`}>
    <div class="container-narrow center" style="position:relative;z-index:1">
      <p class="quote-ar" dir="rtl" lang="ar">إِنَّ ٱلْمُصَّدِّقِينَ وَٱلْمُصَّدِّقَـٰتِ وَأَقْرَضُوا۟ ٱللَّهَ قَرْضًا حَسَنًۭا يُضَـٰعَفُ لَهُمْ وَلَهُمْ أَجْرٌۭ كَرِيمٌۭ ١٨</p>
      <p class="quote-en">Indeed, the men who practice charity and the women who practice charity and [they who] have loaned Allāh a goodly loan – it will be multiplied for them, and they will have a noble reward. – Holy Quran 57:18</p>
    </div>
  </section>
</Base>

<style>
  /* ---------- hero ---------- */
  .report-hero { position: relative; overflow: hidden; padding-top: 56px; padding-bottom: 0; }
  .report-hero-grid { max-width: 620px; }
  .report-hero h1 { margin-bottom: 18px; }
  .report-meta { color: var(--body); font-weight: 500; font-size: 1.05rem; }
  .report-hero-photo {
    margin-top: 40px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 6;
  }
  .report-hero-photo img { width: 100%; height: 100%; object-fit: cover; }

  /* ---------- intro + stats ---------- */
  .report-stats { padding-top: 56px; }
  .report-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .report-intro { font-size: 1.0625rem; color: var(--body); }
  .stat-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 32px;
  }
  .stat-fig { padding: 8px 0; }
  .stat-fig-top { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
  .stat-chip {
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--bg-soft);
    display: flex; align-items: center; justify-content: center; flex: none;
  }
  .stat-chip img { width: 22px; height: 22px; }
  .stat-fig-num { font-size: 1.3rem; font-weight: 700; color: var(--brand); }
  .stat-fig-label { color: var(--body); }

  /* ---------- objective (dark) ---------- */
  .report-objective-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 56px;
    align-items: center;
  }
  .report-objective-grid h2 { font-size: clamp(2.2rem, 5vw, 3.4rem); }
  .report-objective p { color: rgba(255,255,255,0.9); }

  /* ---------- highlight cards ---------- */
  .highlight-icon {
    width: 84px; height: 84px; border-radius: 18px;
    background: var(--bg-soft);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 22px;
  }
  .highlight-icon img { width: 42px; height: 42px; }
  .highlight-card h4 { margin-bottom: 12px; }
  .highlight-card p { font-size: 1rem; }

  /* ---------- split (challenges/conclusion) ---------- */
  .report-split-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 56px;
    align-items: start;
  }
  .report-split-grid h2 { font-size: clamp(2.2rem, 5vw, 3.4rem); }
  .challenge-list { margin: 0; padding-left: 20px; }
  .challenge-list li { margin-bottom: 6px; }

  /* ---------- gallery ---------- */
  .report-gallery { padding-top: 8px; }
  .gallery-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
  .gallery-shot {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: var(--bg-soft);
  }
  .gallery-shot img { width: 100%; height: 100%; object-fit: cover; }

  /* ---------- acknowledgments ---------- */
  .report-ack h2 { font-size: clamp(2.2rem, 5vw, 3.4rem); }
  .ack-rule { border: 0; border-top: 1px solid var(--line); max-width: 560px; margin: 20px auto 28px; }
  .ack-person { margin-top: 36px; }
  .ack-person img {
    width: 170px; height: 200px; object-fit: cover;
    border-radius: var(--radius); margin: 0 auto 14px;
  }
  .ack-person h4 { color: var(--brand); }

  /* ---------- closing quote w/ photo collage ---------- */
  .quote-collage {
    position: relative;
    overflow: hidden;
    background: var(--brand);
    text-align: center;
  }
  .quote-collage::before {
    content: '';
    position: absolute; inset: 0;
    background-image: var(--collage);
    background-size: cover;
    background-position: center;
    opacity: 0.16;
  }
  .quote-collage::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(54, 79, 107, 0.55);
  }
  .quote-ar {
    color: var(--yellow);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.7;
    max-width: 900px;
    margin: 0 auto 24px;
  }
  .quote-en { color: #fff; max-width: 800px; margin: 0 auto; font-size: 1.1rem; }

  /* ---------- responsive ---------- */
  @media (max-width: 900px) {
    .report-stats-grid,
    .report-objective-grid,
    .report-split-grid { grid-template-columns: 1fr; gap: 28px; }
    .gallery-row { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .stat-list { grid-template-columns: 1fr 1fr; }
    .gallery-row { grid-template-columns: 1fr; }
    .report-hero-photo { aspect-ratio: 16 / 10; }
  }
</style>
