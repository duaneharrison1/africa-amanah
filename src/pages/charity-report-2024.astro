---
import Base from '../layouts/Base.astro';
import { ASSET } from '../data/site.js';

const HERO_PHOTO = 'https://africaamanah.com/wp-content/uploads/2025/07/jeff-ackley-YwDo_HwORXs-unsplash-scaled.jpg';
const HADIM = 'https://africaamanah.com/wp-content/uploads/2025/06/Frame-1707483754-1.png';
const COLLAGE = 'https://africaamanah.com/wp-content/uploads/2025/06/unnamed-file.png';

const stats = [
  { icon: '2025/07/tdesign_rice-filled.svg', num: '14', label: 'bags of rice' },
  { icon: '2025/06/lucide-lab_onion.svg', num: '19', label: 'bags of onions' },
  { icon: '2025/06/Frame-1707483721.svg', num: '14', label: 'gallons of cooking oil' },
  { icon: '2025/06/mdi_spoon-sugar.svg', num: '5', label: 'bags of sugar' },
];
const objectives = [
  'To support vulnerable households with basic food supplies',
  'To foster community engagement and strengthen social ties',
  'To promote the Foundation’s mission of alleviating poverty and supporting the underprivileged',
];
const highlights = [
  { icon: '2025/06/Frame-8.svg', title: 'Community Engagement', text: 'The outreach saw active participation from volunteers and community members fostering a spirit of collaboration and support' },
  { icon: '2025/06/Frame-8-1.svg', title: 'Impact', text: 'Each household received essential food items to sustain their families, addressing immediate needs' },
  { icon: '2025/06/Frame-8-2.svg', title: 'Visibility', text: 'The event was conducted by a professional photographer a branded banner, T-shirts and polo T-shirts enhancing the Foundation’s visibility' },
];
const gallery = [
  'https://africaamanah.com/wp-content/uploads/2025/06/C92EAEEB-6766-431C-B15C-025053F3A984.png',
  'https://africaamanah.com/wp-content/uploads/2025/06/BC05E838-CF3C-45CB-B6E4-9A20F51B5EE6.png',
  'https://africaamanah.com/wp-content/uploads/2025/06/IMG_3863.png',
];
---
<Base title="Charity Report 2024 — Africa Amanah Foundation">
  <!-- HERO -->
  <section class="report-hero">
    <span class="rings" style="top:-90px;right:-120px;width:560px;height:560px" aria-hidden="true"></span>
    <div class="container" style="position:relative;z-index:1">
      <div class="report-hero-grid">
        <div>
          <h1>Charity Outreach Report Kunkujang Keitaya 2024</h1>
          <p class="report-meta">📍 Community: Kunkujang Keitaya&nbsp;&nbsp;&nbsp;📅 Date: 29th December 2024</p>
        </div>
      </div>
      <div class="report-hero-photo">
        <img src={HERO_PHOTO} alt="Africa Amanah Foundation outreach" />
      </div>
    </div>
  </section>

  <!-- INTRO + STATS -->
  <section class="report-stats">
    <div class="container">
      <div class="report-stats-grid">
        <p class="report-intro">On 29th December 2024, Africa Amanah Foundation carried out a charity outreach in the Kunkujang Keitaya community, supporting 14 vulnerable households with essential food items and basic supplies.</p>
        <div class="stat-list">
          {stats.map((s) => (
            <div class="stat-fig">
              <div class="stat-fig-top">
                <span class="stat-chip"><img src={`${ASSET}/${s.icon}`} alt="" /></span>
                <span class="stat-fig-num">{s.num}</span>
              </div>
              <div class="stat-fig-label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- OBJECTIVE (dark) -->
  <section class="section-dark report-objective">
    <span class="rings" style="top:-40px;left:-160px;width:560px;height:560px" aria-hidden="true"></span>
    <div class="container" style="position:relative;z-index:1">
      <div class="report-objective-grid">
        <h2>Objective</h2>
        <div>
          {objectives.map((o, i) => (
            <div class="num-item"><div class="num">{i + 1}</div><p>{o}</p></div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- OUTREACH HIGHLIGHT -->
  <section class="report-highlights">
    <div class="container">
      <h2 class="center" style="margin-bottom:48px">Outreach Highlight</h2>
      <div class="grid grid-3">
        {highlights.map((h) => (
          <div class="highlight-card">
            <span class="highlight-icon"><img src={`${ASSET}/${h.icon}`} alt="" /></span>
            <h4>{h.title}</h4>
            <p>{h.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CHALLENGES (soft) -->
  <section class="section-soft report-split">
    <div class="container">
      <div class="report-split-grid">
        <h2>Challenges</h2>
        <div class="stack">
          <p>High transportation cost due to the location of the community.</p>
          <p>We’ve faced challenging transportation difficulties, the initial plan was to hire a Minitruck but that could not be materialise due to the high price they quoted, we ended up hiring two sedan cars to transport the goods and the volunteers followed by foot.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONCLUSION -->
  <section class="report-split">
    <div class="container">
      <div class="report-split-grid">
        <h2>Conclusion</h2>
        <div class="stack">
          <p>The charity outreach in kunkujang keitaya was a success, with 14 households benefiting from essential supplies. Africa Amanah Foundation remains committed to its mission of empowering communities and improving lives.</p>
          <p>The people of kunkujang keitaya community were so delighted and happy to receive the charity donations, they sent their heartfelt gratitude to Africa Amanah Foundation for coming to their rescue at this difficult time, they pray that ALLAH (SWT) grant the wishes of everyone that shared a part of their wealth to help feed them and their families.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="report-gallery">
    <div class="container">
      <div class="gallery-row">
        {gallery.map((g) => (
          <div class="gallery-shot"><img src={g} alt="Outreach photo" /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ACKNOWLEDGMENTS (soft, centered) -->
  <section class="section-soft report-ack">
    <div class="container-narrow center">
      <h2>Acknowledgments</h2>
      <hr class="ack-rule" />
      <p class="lead mx-auto">We extend our heartfelt gratitude to all donors, volunteers and community members who contributed to the success of this outreach.</p>
      <div class="ack-person">
        <img src={HADIM} alt="Hadim Ceesay" />
        <h4>Hadim Ceesay</h4>
      </div>
    </div>
  </section>

  <!-- CLOSING QUOTE -->
  <section class="quote-collage" style={`--collage:url('${COLLAGE}')`}>
    <div class="container-narrow center" style="position:relative;z-index:1">
      <h2 class="quote-text">May Allah (SWT) grant the wishes of all who contributed to this noble cause</h2>
      <p class="quote-by">– Community Message</p>
    </div>
  </section>
</Base>

<style>
  /* ---------- hero ---------- */
  .report-hero { position: relative; overflow: hidden; padding-top: 56px; padding-bottom: 0; }
  .report-hero-grid { max-width: 620px; }
  .report-hero h1 { margin-bottom: 18px; }
  .report-meta { color: var(--body); font-weight: 500; font-size: 1.05rem; }
  .report-hero-photo {
    margin-top: 40px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 6;
  }
  .report-hero-photo img { width: 100%; height: 100%; object-fit: cover; }

  /* ---------- intro + stats ---------- */
  .report-stats { padding-top: 56px; }
  .report-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .report-intro { font-size: 1.0625rem; color: var(--body); }
  .stat-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 32px;
  }
  .stat-fig { padding: 8px 0; }
  .stat-fig + .stat-fig {}
  .stat-fig-top { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
  .stat-chip {
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--bg-soft);
    display: flex; align-items: center; justify-content: center; flex: none;
  }
  .stat-chip img { width: 22px; height: 22px; }
  .stat-fig-num { font-size: 1.3rem; font-weight: 700; color: var(--brand); }
  .stat-fig-label { color: var(--body); }

  /* ---------- objective (dark) ---------- */
  .report-objective-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 56px;
    align-items: center;
  }
  .report-objective-grid h2 { font-size: clamp(2.2rem, 5vw, 3.4rem); }
  .report-objective .num-item { border-bottom-color: rgba(255,255,255,0.18); }
  .report-objective .num-item .num { color: var(--yellow); font-size: 1.4rem; margin-bottom: 6px; }
  .report-objective .num-item p { color: rgba(255,255,255,0.9); }

  /* ---------- highlight cards ---------- */
  .highlight-icon {
    width: 84px; height: 84px; border-radius: 18px;
    background: var(--bg-soft);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 22px;
  }
  .highlight-icon img { width: 42px; height: 42px; }
  .highlight-card h4 { margin-bottom: 12px; }
  .highlight-card p { font-size: 1rem; }

  /* ---------- split (challenges/conclusion) ---------- */
  .report-split-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 56px;
    align-items: start;
  }
  .report-split-grid h2 { font-size: clamp(2.2rem, 5vw, 3.4rem); }

  /* ---------- gallery ---------- */
  .report-gallery { padding-top: 8px; }
  .gallery-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
  .gallery-shot {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: var(--bg-soft);
  }
  .gallery-shot img { width: 100%; height: 100%; object-fit: cover; }

  /* ---------- acknowledgments ---------- */
  .report-ack h2 { font-size: clamp(2.2rem, 5vw, 3.4rem); }
  .ack-rule { border: 0; border-top: 1px solid var(--line); max-width: 560px; margin: 20px auto 28px; }
  .ack-person { margin-top: 36px; }
  .ack-person img {
    width: 170px; height: 200px; object-fit: cover;
    border-radius: var(--radius); margin: 0 auto 14px;
  }
  .ack-person h4 { color: var(--brand); }

  /* ---------- closing quote w/ photo collage ---------- */
  .quote-collage {
    position: relative;
    overflow: hidden;
    background: var(--brand);
    text-align: center;
  }
  .quote-collage::before {
    content: '';
    position: absolute; inset: 0;
    background-image: var(--collage);
    background-size: cover;
    background-position: center;
    opacity: 0.16;
  }
  .quote-collage::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(54, 79, 107, 0.55);
  }
  .quote-text { color: #fff; max-width: 820px; margin: 0 auto; font-weight: 600; }
  .quote-by { color: rgba(255,255,255,0.85); margin-top: 18px; font-size: 1.05rem; }

  /* ---------- responsive ---------- */
  @media (max-width: 900px) {
    .report-stats-grid,
    .report-objective-grid,
    .report-split-grid { grid-template-columns: 1fr; gap: 28px; }
    .gallery-row { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .stat-list { grid-template-columns: 1fr 1fr; }
    .gallery-row { grid-template-columns: 1fr; }
    .report-hero-photo { aspect-ratio: 16 / 10; }
  }
</style>
