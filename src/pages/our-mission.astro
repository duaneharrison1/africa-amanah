---
import Base from '../layouts/Base.astro';
import { ASSET, donateUrl } from '../data/site.js';

const values = [
  { icon: 'Wells.svg', title: 'Poverty Alleviation', text: 'Providing essential food, clothing, and healthcare support to the underprivileged' },
  { icon: 'Loves.svg', title: 'Education Empowerment', text: 'Supporting access to education for children and young people across Gambia and beyond' },
  { icon: 'Peoples.svg', title: 'Community Upliftment', text: 'Creating sustainable programs that build resilient communities.' },
  { icon: 'Peoples.svg', title: 'Social Welfare', text: 'Offering recreational and development programs to improve lives and restore hope' },
];
---
<Base title="Our Mission — Africa Amanah Foundation">
  <section class="page-header" style="position:relative; overflow:hidden">
    <span class="rings" style="top:-90px; right:-150px; width:620px; height:620px" aria-hidden="true"></span>
    <div class="container" style="position:relative; z-index:1">
      <h1 style="margin-bottom:24px">Our Mission</h1>
      <p class="eyebrow" style="max-width:1000px">At Africa Amanah Foundation (AAF), every act of kindness is charity. We believe that together, we can create lasting change. Our work is rooted in compassion, solidarity, and the belief that every individual deserves access to basic necessities and opportunities to thrive.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <h2 class="center" style="margin-bottom:48px">What We Stand For</h2>
      <div class="grid grid-4">
        {values.map((v) => (
          <div class="service-card">
            <div class="icon-box"><img src={`${ASSET}/2025/06/${v.icon}`} alt="" /></div>
            <h4>{v.title}</h4>
            <p>{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta section-dark center">
    <div class="container">
      <h2>We are committed to being a force for good, one act of kindness at a time</h2>
      <a href={donateUrl} target="_blank" rel="noopener" class="btn" style="margin-top:28px">Join Campaigns</a>
    </div>
  </section>
</Base>
