---
import Base from '../../layouts/Base.astro';
import { team } from '../../data/site.js';
---
<Base title="Our Team — Africa Amanah Foundation">
  <section class="page-header team-hero">
    <span class="rings" style="top:-40px;right:-180px;width:760px;height:760px" aria-hidden="true"></span>
    <div class="container" style="position:relative;z-index:1">
      <div class="team-intro">
        <h2>Our Team</h2>
        <p class="lead">Our team includes an Executive board based in London and the Gambia who work with the International Director in Hong Kong. It is truly a global effort to organise outreach programs, build partnerships, raise awareness and work tirelessly on the ground to uplift lives and restore dignity.</p>
      </div>
    </div>
  </section>

  <section class="team-grid-section" style="padding-top:32px">
    <span class="rings" style="bottom:-260px;right:-200px;width:760px;height:760px" aria-hidden="true"></span>
    <div class="container" style="position:relative;z-index:1">
      <div class="grid grid-4">
        {team.map((m) => (
          <a class="team-card" href={m.href}>
            <div class="photo"><img src={m.photo} alt={m.name} /></div>
            <h4>{m.name}</h4>
            <div class="role">{m.role}</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .team-hero { position: relative; overflow: hidden; }
  .team-grid-section { position: relative; overflow: hidden; }
  .team-intro {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }
  .team-intro h2 { margin: 0; }
  .team-intro .lead { margin: 0; }

  /* Team cards sit on a faint rounded panel */
  .team-grid-section .team-card {
    background: #f6f8fc;
    border-radius: 22px;
    padding: 28px 28px 32px;
  }
  .team-grid-section .team-card .photo {
    aspect-ratio: auto;
    background: transparent;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 22px;
  }
  .team-grid-section .team-card .photo img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }
  .team-grid-section .team-card h4 { margin-bottom: 8px; }
  .team-grid-section .team-card .role { font-size: 1rem; }

  @media (max-width: 900px) {
    .team-intro { grid-template-columns: 1fr; gap: 20px; }
  }
</style>
