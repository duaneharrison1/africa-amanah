---
import { contact, ASSET } from '../data/site.js';
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <a href="/" class="logo" aria-label="Africa Amanah Foundation — home">
          <img src={`${ASSET}/2025/06/Group-2.svg`} alt="Africa Amanah Foundation" style="height:52px" />
        </a>
        <p class="tagline">Creating a better world, one cause at a time</p>
        <div class="f-contact">
          <svg viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24 11.4 11.4 0 0 0 3.57.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2Z"/></svg>
          <span>{contact.phone}</span>
        </div>
        <div class="f-contact">
          <svg viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4-8 5-8-5V6l8 5 8-5v2Z"/></svg>
          <span>{contact.email}</span>
        </div>
      </div>

      <div class="footer-col">
        <h6>Menu</h6>
        <ul>
          <li><a href="/about-us/">About Us</a></li>
          <li><a href="/our-mission/">Our Mission</a></li>
          <li><a href="/where-is-the-gambia/">Where is the Gambia</a></li>
          <li><a href="/gallery/">Gallery</a></li>
          <li><a href="/contact-us/">Contact Us</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h6>Campaigns</h6>
        <ul>
          <li><a href="/charity-report-2024/">Charity Report 2024</a></li>
          <li><a href="/charity-report-2025/">Charity Report 2025</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">© {new Date().getFullYear()} Africa Amanah Foundation. All rights reserved.</div>
  </div>
</footer>
